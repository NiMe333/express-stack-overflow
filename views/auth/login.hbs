<h2 class="mb-4">Prijava</h2>

<form method="POST" action="/auth/login" class="card p-4 shadow-sm">
    <div class="mb-3">
        <label>Email</label>
        <input type="email" name="email" class="form-control" required>
    </div>

    <div class="mb-3">
        <label>Geslo</label>
        <input type="password" name="password" class="form-control" required>
    </div>

    <button class="btn btn-primary w-100">Prijava</button>
</form>

<p class="mt-3">
    Nimaš računa? <a href="/auth/register">Registracija</a>
</p>„