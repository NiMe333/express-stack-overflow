<html>

<head>
  <title>{{title}}</title>
  <link rel="stylesheet" href="/stylesheets/style.css" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>

<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand" href="/">Stack overflow app</a>

      <div>
        {{#if user}}
        <img src="{{user.profileImage}}" width="30" class="rounded-circle" />
        <a href="/user/profile/{{user._id}}" class="text-white me-2">
          {{user.username}}
        </a>

        <a href="/auth/logout" class="btn btn-outline-light btn-sm">Logout</a>
        {{else}}
        <a href="/auth/login" class="btn btn-outline-light btn-sm">Login</a>
        {{/if}}
      </div>
    </div>
  </nav>
  <div class="container mt-5">
    {{{body}}}
  </div>
</body>

</html>