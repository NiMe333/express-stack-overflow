<h2 class="mb-4">Vsa vprašanja</h2>

<a href="/questions/new" class="btn btn-primary mb-3">+ Dodaj vprašanje</a>

{{#if questions.length}}
{{#each questions}}
<div class="card mb-3 p-3 shadow-sm">
  <h5>
    <a href="/questions/{{this._id}}" class="text-decoration-none">
      {{this.title}}
    </a>
  </h5>
  <p>{{this.description}}</p>
  <small class="text-muted">{{this.formattedDate}}</small>
</div>
{{/each}}
{{else}}
<p>Ni še vprašanj.</p>
{{/if}}